# ════════════════════════════════════════════════════════════
#  Frontend Environment Variables
#  ⚠️  Copy to .env.local for local dev — it's in .gitignore
#  ⚠️  In Vercel: set these in Dashboard → Settings → Env Vars
# ════════════════════════════════════════════════════════════

# Backend API URL
# Local dev: leave as-is (Vite proxy handles /api/* automatically)
# Production: set to your Render backend URL
# Example: https://ai-interview-backend.onrender.com
VITE_API_URL=http://localhost:8000

# ════════════════════════════════════════════════════════════
#  SECURITY RULES FOR FRONTEND
#  ✓ Only VITE_ prefixed vars are safe — they're public
#  ✗ NEVER put GROQ_API_KEY here — it would be exposed in browser
#  ✗ NEVER put MONGODB_URI here — it would be exposed in browser
#  ✓ All AI/DB calls go through the FastAPI backend only
# ════════════════════════════════════════════════════════════
