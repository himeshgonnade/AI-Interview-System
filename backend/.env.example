# ════════════════════════════════════════════════════════════
#  AI Interview Simulator — Environment Variables Template
#  ⚠️  Copy this file to .env and fill in real values
#  ⚠️  NEVER commit .env to git — it's in .gitignore
# ════════════════════════════════════════════════════════════

# ── LLM (Groq) ───────────────────────────────────────────────
# Get a FREE key at: https://console.groq.com
# Used for: question generation, answer evaluation, report generation
GROQ_API_KEY=your_groq_api_key_here

# ── Database (MongoDB Atlas) ──────────────────────────────────
# Get a FREE M0 cluster at: https://mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai_interview?retryWrites=true&w=majority
DATABASE_NAME=ai_interview

# ── App Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be changed before deploying to production
SECRET_KEY=change-this-in-production

# ── Environment ───────────────────────────────────────────────
# Values: development | production
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────
# Your deployed Vercel frontend URL (set this in Render dashboard for prod)
# Example: https://ai-interview-simulator.vercel.app
FRONTEND_URL=http://localhost:5173

# ════════════════════════════════════════════════════════════
#  DEPLOYMENT GUIDE
# ════════════════════════════════════════════════════════════
#
#  Render (Backend):
#    Dashboard → Your Service → Environment → Add env var
#    Add: GROQ_API_KEY, MONGODB_URI, SECRET_KEY, ENVIRONMENT=production, FRONTEND_URL
#    ✓ Render injects these automatically — no .env file needed on server
#
#  Vercel (Frontend):
#    Dashboard → Your Project → Settings → Environment Variables
#    Add: VITE_API_URL=https://your-render-service.onrender.com
#    ✓ Only VITE_ prefixed vars are exposed to the browser
#    ✓ Never put GROQ_API_KEY or MONGODB_URI in Vercel — backend only!
#
# ════════════════════════════════════════════════════════════
